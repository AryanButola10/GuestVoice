name: W6_AuthAPICollection_TBI-26101147
item:
  - name: Register User
    request:
      method: POST
      url: "{{base_url}}/auth/register"
      header:
        - key: Content-Type
          value: application/json
      body:
        mode: raw
        raw: |
          {
            "name": "Aryan Butola",
            "email": "aryan.postman@gmail.com",
            "password": "securepass123"
          }
  - name: Login User
    event:
      - listen: test
        script:
          exec:
            - "const res = pm.response.json();"
            - "pm.environment.set('token', res.access_token);"
            - "console.log('Token saved:', res.access_token);"
    request:
      method: POST
      url: "{{base_url}}/auth/login"
      header:
        - key: Content-Type
          value: application/json
      body:
        mode: raw
        raw: |
          {
            "email": "aryan.postman@gmail.com",
            "password": "securepass123"
          }
  - name: Create Review (Protected)
    request:
      method: POST
      url: "{{base_url}}/reviews"
      header:
        - key: Content-Type
          value: application/json
        - key: Authorization
          value: "Bearer {{token}}"
      body:
        mode: raw
        raw: |
          {
            "guest_name": "Postman Test User",
            "property": "Test Hotel Shimla",
            "rating": 5,
            "review_text": "Excellent stay highly recommended clean and friendly staff great location"
          }
  - name: Get All Reviews (Protected)
    request:
      method: GET
      url: "{{base_url}}/reviews"
      header:
        - key: Authorization
          value: "Bearer {{token}}"
  - name: Get Stats (Public)
    request:
      method: GET
      url: "{{base_url}}/stats"
  - name: POST Reviews Without Token (Should Return 401)
    request:
      method: POST
      url: "{{base_url}}/reviews"
      header:
        - key: Content-Type
          value: application/json
      body:
        mode: raw
        raw: |
          {
            "guest_name": "No Auth Test",
            "property": "Test",
            "rating": 3,
            "review_text": "This should return 401 unauthorized"
          }
